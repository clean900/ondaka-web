# ===========================================================
# ONDAKA — Gestão de Condomínios Angola
# Ficheiro de configuração
# Soluções Simples © 2026
# ===========================================================

APP_NAME=Ondaka
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Africa/Luanda
APP_URL=https://ondaka.ao

APP_LOCALE=pt
APP_FALLBACK_LOCALE=pt
APP_FAKER_LOCALE=pt_PT

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ===========================================================
# BASE DE DADOS
# No cPanel: usar credenciais MySQL criadas no cPanel
# ===========================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ondaka_producao
DB_USERNAME=ondaka_user
DB_PASSWORD=

# ===========================================================
# SESSÃO, CACHE, FILAS
# Se tens Redis disponível, muda para redis
# Se não tens, mantém database
# ===========================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=pusher
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=ondaka

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ===========================================================
# EMAIL
# ===========================================================
MAIL_MAILER=smtp
MAIL_HOST=mail.ondaka.ao
MAIL_PORT=465
MAIL_USERNAME=noreply@ondaka.ao
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="noreply@ondaka.ao"
MAIL_FROM_NAME="${APP_NAME}"

# ===========================================================
# PUSHER — Tempo real (Chat, Notificações)
# Criar conta em pusher.com (plano free permite 200k msg/dia)
# ===========================================================
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=eu

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ===========================================================
# PROXYPAY — Pagamentos Angola
# Docs: https://developer.proxypay.co.ao
# ===========================================================
PROXYPAY_BASE_URL=https://api.proxypay.co.ao
PROXYPAY_SANDBOX_URL=https://api.sandbox.proxypay.co.ao
PROXYPAY_MODE=sandbox
PROXYPAY_API_KEY=
PROXYPAY_ENTITY_ID=
PROXYPAY_WEBHOOK_SECRET=

# ===========================================================
# TELCOSMS — SMS Angola
# Usado para 2FA e notificações SMS
# ===========================================================
TELCOSMS_API_URL=https://api.telcosms.co.ao/v1/sms/send
TELCOSMS_API_KEY=
TELCOSMS_SENDER_ID=ONDAKA

# ===========================================================
# FIREBASE — Push notifications (Mobile Flutter)
# ===========================================================
FIREBASE_CREDENTIALS=storage/app/firebase/credentials.json
FIREBASE_PROJECT_ID=

# ===========================================================
# ZKTECO — Biometria Prestadores
# ===========================================================
ZKTECO_DEFAULT_PORT=4370
ZKTECO_DEFAULT_TIMEOUT=10

# ===========================================================
# HIKVISION — ANPR (Reconhecimento de Matrículas)
# ===========================================================
HIKVISION_USERNAME=
HIKVISION_PASSWORD=

# ===========================================================
# CONFORMIDADE LEGAL DP 141/15
# ===========================================================
DP14115_PERCENTAGEM_FUNDO_RESERVA_MINIMA=10.00
DP14115_LIMITE_QUOTA_UCF_POR_M2=6.00
